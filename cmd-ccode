#!/bin/bash
ulimit -n 10240
env -i \
  HOME="$HOME" \
  USER="$USER" \
  PATH="$PATH" \
  TERM="$TERM" \
  COLORTERM="$COLORTERM" \
  LANG="${LANG:-en_US.UTF-8}" \
  NODE_ENV="production" \
  NODE_OPTIONS="--max-old-space-size=4096" \
  sandbox-exec -f mac-sandbox-policy.sb -D HOME="$HOME" ~/.local/share/claude/versions/2.1.101
