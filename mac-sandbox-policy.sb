(version 1)
(allow default)

;; 1. DENY personal folders only (The "Blacklist" approach)
(deny file-read* file-write*
    (subpath (string-append (param "HOME") "/Documents"))
    (subpath (string-append (param "HOME") "/Desktop"))
    (subpath (string-append (param "HOME") "/Downloads"))
    (subpath (string-append (param "HOME") "/Pictures"))
    (subpath (string-append (param "HOME") "/.ssh")))

;; 2. ALLOW everything else in HOME (needed for Node/Claude to boot)
(allow file-read* file-write*
    (subpath (string-append (param "HOME") "/.claude"))
    (subpath (string-append (param "HOME") "/.local"))
    (subpath "."))

;; 3. FIX for "Unknown error": Allow system temp and metadata
(allow file-read* file-write* (subpath "/private/var/folders"))
(allow mach-lookup)

