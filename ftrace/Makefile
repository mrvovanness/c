# Сборка демонстрационной программы для трассировки ftrace.
#
# Статическая сборка (-static) выбрана осознанно:
#   * бинарник не зависит от версии libc и запускается в любой среде той же
#     архитектуры (в т.ч. в минимальном образе CoreOS, где нет тулчейна);
#   * отсутствует динамический загрузчик ld.so, поэтому на старте процесса
#     нет «шумных» системных вызовов открытия/маппинга .so-библиотек —
#     трасса системных вызовов получается чище и нагляднее.
#
# -O0 -g сохраняют прямое соответствие между строками кода и вызовами.

CC      ?= cc
CFLAGS  ?= -O0 -g -Wall -Wextra -static
TARGET  := syscall_demo
SRC     := syscall_demo.c

$(TARGET): $(SRC)
	$(CC) $(CFLAGS) -o $@ $<

run: $(TARGET)
	./$(TARGET)

clean:
	rm -f $(TARGET)

.PHONY: run clean
